---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, cover, tags, date } = project.data;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  timeZone: 'UTC',
});
---
<a
  href={`/projects/${project.id}/`}
  class="group block overflow-hidden rounded-lg border border-[var(--color-border)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-soft)] dark:bg-[var(--color-bg-dark-soft)] transition-shadow hover:shadow-lg"
>
  {cover && (
    <div class="aspect-[4/3] overflow-hidden bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)]">
      <Image
        src={cover}
        alt={title}
        widths={[400, 800]}
        sizes="(min-width: 768px) 33vw, 100vw"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    </div>
  )}
  <div class="p-5">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class="font-serif text-xl group-hover:text-[var(--color-accent-600)] transition-colors">
        {title}
      </h3>
      <time
        datetime={date.toISOString()}
        class="shrink-0 rounded-full border border-[var(--color-accent-200)] bg-[var(--color-accent-50)] px-2 py-0.5 text-xs text-[var(--color-accent-700)] dark:border-[var(--color-accent-800)] dark:bg-transparent dark:text-[var(--color-accent-300)]"
      >
        {formattedDate}
      </time>
    </div>
    <p class="mt-2 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] line-clamp-2">
      {summary}
    </p>
    {tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((t) => (
          <li class="rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] px-2 py-0.5 text-xs text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
            {t}
          </li>
        ))}
      </ul>
    )}
  </div>
</a>
