---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const musicFeatured = await getCollection('music', ({ data }) => data.featured && !data.draft);
const sportsFeatured = await getCollection('sports', ({ data }) => data.featured && !data.draft);
const featured = [...musicFeatured, ...sportsFeatured]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  });
---
<BaseLayout title="Jeffrey Wang">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <h1 class="font-serif text-5xl font-light tracking-tight sm:text-6xl">
      Hi, I&rsquo;m <span class="font-medium text-[var(--color-accent-600)]">Jeffrey</span>.
    </h1>
    <p class="mt-6 max-w-xl text-lg text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
      doing random stuff for fun
    </p>
  </section>

  {featured.length > 0 && (
    <section class="mx-auto max-w-3xl px-6 pb-20">
      <h2 class="font-serif text-2xl border-b border-[var(--color-border)] dark:border-[var(--color-border-dark)] pb-3">
        Featured
      </h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-3">
        {featured.map((entry) => {
          const { title, date, venue, youtubeId, instagram, cover, tags } = entry.data;
          const yt = youtubeId ? `https://www.youtube.com/watch?v=${youtubeId}` : null;
          const thumb = youtubeId ? `https://i.ytimg.com/vi/${youtubeId}/mqdefault.jpg` : null;
          const link = yt ?? instagram ?? '#';
          return (
            <a
              href={link}
              target={link === '#' ? undefined : '_blank'}
              rel={link === '#' ? undefined : 'noopener noreferrer'}
              class="group block overflow-hidden rounded-lg border border-[var(--color-border)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-soft)] dark:bg-[var(--color-bg-dark-soft)] transition-shadow hover:shadow-lg"
            >
              {thumb ? (
                <div class="aspect-video overflow-hidden bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)]">
                  <img src={thumb} alt={title} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
                </div>
              ) : cover ? (
                <div class="aspect-video overflow-hidden bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)]">
                  <Image
                    src={cover}
                    alt={title}
                    widths={[300, 600]}
                    sizes="(min-width: 768px) 16rem, 100vw"
                    class="h-full w-full object-cover object-[center_10%] transition-transform duration-500 group-hover:scale-[1.03]"
                  />
                </div>
              ) : (
                <div class="aspect-video bg-[var(--color-bg)] dark:bg-[var(--color-bg-dark)]"></div>
              )}
              <div class="p-4">
                <h3 class="font-serif text-lg leading-tight group-hover:text-[var(--color-accent-600)] transition-colors">
                  {title}
                </h3>
                <p class="mt-1 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
                  {fmtDate(date)}{venue ? ` · ${venue}` : ''}
                </p>
                {tags.length > 0 && (
                  <ul class="mt-2 flex flex-wrap gap-1.5">
                    {tags.slice(0, 3).map((t) => (
                      <li class="rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] px-2 py-0.5 text-xs text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
                        {t}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>
