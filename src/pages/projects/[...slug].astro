---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, date, tags, cover, links } = project.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---
<BaseLayout title={`${title} — Jeffrey Wang`} description={summary}>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-20">
    <a href="/projects/" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent-500)] dark:text-[var(--color-muted-dark)] transition-colors">
      &larr; All projects
    </a>

    <header class="mt-6 border-b border-[var(--color-border)] dark:border-[var(--color-border-dark)] pb-8">
      <h1 class="font-serif text-4xl font-light tracking-tight sm:text-5xl">{title}</h1>
      <p class="mt-3 text-lg text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">{summary}</p>
      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <ul class="flex flex-wrap gap-1.5">
              {tags.map((t) => (
                <li class="rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] px-2 py-0.5 text-xs">
                  {t}
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
      {(links?.github || links?.demo) && (
        <div class="mt-5 flex flex-wrap gap-3 text-sm">
          {links.demo && (
            <a class="rounded-md bg-[var(--color-accent-500)] px-3 py-1.5 text-white hover:bg-[var(--color-accent-600)] transition-colors" href={links.demo} target="_blank" rel="noopener noreferrer">
              View demo &rarr;
            </a>
          )}
          {links.github && (
            <a class="rounded-md border border-[var(--color-border)] dark:border-[var(--color-border-dark)] px-3 py-1.5 hover:border-[var(--color-accent-500)] hover:text-[var(--color-accent-500)] transition-colors" href={links.github} target="_blank" rel="noopener noreferrer">
              GitHub
            </a>
          )}
        </div>
      )}
    </header>

    {cover && (
      <div class="mt-8 overflow-hidden rounded-lg border border-[var(--color-border)] dark:border-[var(--color-border-dark)] bg-[var(--color-bg-soft)] dark:bg-[var(--color-bg-dark-soft)]">
        <Image src={cover} alt={title} widths={[600, 1200]} sizes="(min-width: 768px) 768px, 100vw" class="w-full" />
      </div>
    )}

    <div class="prose prose-zinc dark:prose-invert mt-10 max-w-none prose-a:text-[var(--color-accent-600)] prose-a:no-underline hover:prose-a:underline prose-headings:font-serif">
      <Content />
    </div>
  </article>
</BaseLayout>
